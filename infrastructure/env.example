# Environment Variables — Idea-to-Product OS
# Copy this to ~/ai-agents/.env and fill in your values
# Never commit .env to version control

# ── Core (required for all agents) ───────────────────────────────────────────
DISCORD_TOKEN=your_main_discord_bot_token
GROQ_API_KEY=your_groq_api_key

# ── Session Scribe ────────────────────────────────────────────────────────────
DOCS_PATH=/app/docs

# ── Org Schema Formatter ──────────────────────────────────────────────────────
CHANNEL_ID=your_schema_channel_id

# ── Assignment Dispatcher ─────────────────────────────────────────────────────
DISPATCHER_TOKEN=your_dispatcher_bot_token
DISPATCHER_CHANNEL_ID=your_dispatcher_channel_id

# ── Add new agent vars below as you deploy them ───────────────────────────────

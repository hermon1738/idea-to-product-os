# env.example — Idea-to-Product OS
#
# SETUP:
#   1. Copy to .env at your project root:
#        cp templates/env.example .env
#   2. Fill in the values below
#   3. bricklayer auto-loads .env at startup — no sourcing needed
#
# DOCS ISOLATION:
#   DOCS_PATH controls where bricklayer close-session writes its docs.
#   Each project should have its own DOCS_PATH pointing to that
#   project's docs directory — not the shared ai-agents/docs/.
#
#   idea-to-product-os:  DOCS_PATH=/path/to/ai-agents/docs
#   reddit-monitor:      DOCS_PATH=/path/to/reddit-monitor/docs
#   client-project:      DOCS_PATH=/path/to/client-project/docs
#
#   This prevents one project's session logs from polluting another.
#
# SECURITY:
#   Never commit .env to git. Already in .gitignore.

# ── LLM Provider ─────────────────────────────────────────────────
# Required for: bricklayer close-session (sprint review)
# Default: Groq (free tier). To switch, change the key and update
# bricklayer.yaml llm.api_key_env to match.

GROQ_API_KEY=

# OpenAI alternative:
# OPENAI_API_KEY=
# Then in bricklayer.yaml: provider: openai, api_key_env: OPENAI_API_KEY

# Anthropic alternative:
# ANTHROPIC_API_KEY=
# Then in bricklayer.yaml: provider: anthropic, api_key_env: ANTHROPIC_API_KEY

# ── Docs Sync ─────────────────────────────────────────────────────
# Path to THIS PROJECT's docs directory.
# bricklayer close-session writes decision-log.md and
# pipeline-status.md here after every sprint review.
#
# For idea-to-product-os infrastructure work:
#   DOCS_PATH=/path/to/ai-agents/docs
#
# For a new product (e.g. reddit-monitor):
#   DOCS_PATH=/path/to/reddit-monitor/docs
#
# Leave blank to skip docs sync entirely.
DOCS_PATH=

# ── Agent Deploy ──────────────────────────────────────────────────
# Required for: bricklayer agent deploy
# Path to your local clone of the deploy repo (hermon1738/ai-agents)
# This is the same for all projects.
DEPLOY_REPO_PATH=
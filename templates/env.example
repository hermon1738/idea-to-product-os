# .env — place this file at your project root alongside bricklayer.yaml.
# Rename to .env and fill in your values.
#
# bricklayer loads this file automatically at startup.
# Keys already set in your shell environment are NOT overwritten.
# Add .env to your project .gitignore — never commit secrets.

# Groq API key — required for bricklayer close-session (sprint review).
GROQ_API_KEY=your_groq_key_here

# Path to VPS docs directory — optional.
# Used by close-session to sync decision-log.md and pipeline-status.md.
# Leave commented out if your VPS docs are not mounted locally.
# DOCS_PATH=/path/to/your/docs
